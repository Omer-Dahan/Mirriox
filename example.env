# ── Telegram Bot API ──────────────────────────────────────────────────────────
# Token from @BotFather
BOT_TOKEN=123456789:ABCDefGhIJKlmnoPQRsTUVwxyZ

# ── Telethon (userbot) ────────────────────────────────────────────────────────
# Get from https://my.telegram.org/apps
TELETHON_API_ID=12345678
TELETHON_API_HASH=abcdef1234567890abcdef1234567890

# Path for the Telethon session file (no .session extension needed)
TELETHON_SESSION=sessions/userbot

# ── Authorization ─────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs allowed to use the management bot
# These are always authorized regardless of the admins DB table
ADMIN_IDS=123456789,987654321

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=mirriox.db

# ── Worker tuning ─────────────────────────────────────────────────────────────
# How often the worker checks for new jobs (seconds)
WORKER_POLL_INTERVAL_S=5
